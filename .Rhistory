rmds <- bookdown:::load_config()$rmd_files
rmds <- rmds[!is.na(rmds)]
check_h1 <- function(f){
x <- readLines(f, warn = FALSE, encoding = "UTF-8")
# quitar YAML inicial si existe
if (length(x) >= 1 && grepl("^---\\s*$", x[1])) {
end <- which(grepl("^---\\s*$", x[-1]))[1] + 1
if (!is.na(end)) x <- x[(end+1):length(x)]
}
# quitar líneas vacías al inicio
x <- x[grepl("\\S", x)]
h1 <- any(grepl("^#\\s+\\S", x))
first_h1 <- if (length(x)) grepl("^#\\s+\\S", x[1]) else FALSE
c(file=f, has_any_h1=h1, starts_with_h1=first_h1, first_line=if(length(x)) x[1] else "")
}
res <- do.call(rbind, lapply(rmds, check_h1))
res
